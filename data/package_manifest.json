{
  "schema_version": "biomedpilot.package_manifest.v1",
  "medical_terms_index": {
    "scope": "BioMedPilot shared vocabulary interface",
    "shared_layer": "app/shared/query_intelligence/medical_terms",
    "not_bioinformatics_specific": true,
    "included_in_default_package": [],
    "optional_enhancement": "dev/shared-vocabulary supplies data/medical_terms assets",
    "optional_full_index_included": false,
    "runtime_fallback_order": [
      "external zh_term_overrides.json if present",
      "external medical_terms_index.sqlite if present",
      "external mini_medical_terms_index.json if present",
      "biomedical_term_registry"
    ]
  }
}
