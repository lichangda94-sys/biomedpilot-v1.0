{
  "schema_version": "biomedpilot.analysis_module_manifest.v1",
  "module_id": "survival",
  "title": "Survival analysis",
  "standard_entrypoint": "analysis/runners/run_module.R",
  "input_schema": "analysis/schemas/input/module_input.schema.json",
  "output_schema": "analysis/schemas/output/result_package.schema.json",
  "modes": {
    "mock": {
      "supported": true,
      "fixture_input": "analysis/fixtures/inputs/survival/module_input.json",
      "fixture_output_package": "analysis/fixtures/outputs/survival/mock_result_package"
    },
    "lite": {
      "supported": true,
      "fixture_input": "analysis/fixtures/inputs/survival/module_input_lite.json",
      "runner": "analysis/runners/run_module.R",
      "worker_backend": "rscript",
      "environment": "r-bio-core",
      "result_semantics": "testing_level",
      "capability": "base_r_km_logrank_fixture",
      "clinical_conclusion_policy": "not_generated"
    },
    "full": {
      "supported": true,
      "runner": "analysis/runners/run_module.R",
      "worker_backend": "rscript",
      "environment": "r-bio-full",
      "result_semantics": "formal_computed_result",
      "capability": "survival_minimal_v1_km_logrank_univariate_cox_multivariate_cox",
      "resource_profile": "clinical_fixture_only",
      "excluded_methods": [
        "time_dependent_roc",
        "nomogram",
        "calibration",
        "competing_risk"
      ],
      "clinical_conclusion_policy": "not_generated"
    }
  },
  "environment": {
    "app_dev": "docker/Dockerfile.app-dev",
    "lite": "docker/Dockerfile.r-bio-core",
    "full": "docker/Dockerfile.r-bio-full",
    "renv_lite": "renv/renv.bio-core.lock",
    "renv_full": "renv/renv.bio-full.lock"
  },
  "analysis_environment": "r-bio-core",
  "full_environment": "r-bio-full",
  "environment_lock": "renv/renv.bio-full.lock",
  "dockerfile": "docker/Dockerfile.r-bio-full",
  "dependency_policy": {
    "detection": "detect_first",
    "runtime_install": "forbidden",
    "default_app_dependency": false
  },
  "result_package_contract": "analysis/schemas/output/result_package.schema.json",
  "result_payload_schema": "analysis/schemas/output/result.schema.json",
  "provenance_payload_schema": "analysis/schemas/output/provenance.schema.json",
  "result_package_required": ["result.json", "provenance.json", "tables", "plots", "reports", "logs"],
  "clinical_conclusion_policy": "not_generated_by_default"
}
