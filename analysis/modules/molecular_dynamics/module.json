{
  "schema_version": "biomedpilot.analysis_module_manifest.v1",
  "module_id": "molecular_dynamics",
  "title": "Molecular dynamics",
  "standard_entrypoint": "analysis/runners/run_module.R",
  "input_schema": "analysis/schemas/input/module_input.schema.json",
  "output_schema": "analysis/schemas/output/result_package.schema.json",
  "modes": {
    "mock": {"supported": true, "fixture_input": "analysis/fixtures/inputs/molecular_dynamics/module_input.json", "fixture_output_package": "analysis/fixtures/outputs/molecular_dynamics/mock_result_package"},
    "lite": {"supported": true, "fixture_input": "analysis/fixtures/inputs/molecular_dynamics/module_input_lite.json", "runner": "analysis/runners/run_module.R", "worker_backend": "rscript", "environment": "r-bio-core", "result_semantics": "testing_level", "capability": "gromacs_command_manifest_fixture_no_execution", "external_tool_execution": "not_executed_in_lite_mode"},
    "full": {"supported": false, "blocker": "r_chem_gpu_container_not_available"}
  },
  "environment": {
    "app_dev": "docker/Dockerfile.app-dev",
    "lite": "docker/Dockerfile.r-bio-core",
    "full": "docker/Dockerfile.r-chem-gpu",
    "renv_lite": "renv/renv.bio-core.lock",
    "renv_full": "renv/renv.chem-full.lock"
  },
  "analysis_environment": "r-bio-core",
  "full_environment": "r-chem-gpu",
  "environment_lock": "renv/renv.chem-full.lock",
  "dockerfile": "docker/Dockerfile.r-chem-gpu",
  "dependency_policy": {
    "detection": "detect_first",
    "runtime_install": "forbidden",
    "default_app_dependency": false
  },
  "result_package_contract": "analysis/schemas/output/result_package.schema.json",
  "result_payload_schema": "analysis/schemas/output/result.schema.json",
  "provenance_payload_schema": "analysis/schemas/output/provenance.schema.json",
  "result_package_required": ["result.json", "provenance.json", "tables", "plots", "reports", "logs"],
  "external_tool_policy": "R_adapter_calls_GROMACS_in_chem_gpu_environment_only"
}
