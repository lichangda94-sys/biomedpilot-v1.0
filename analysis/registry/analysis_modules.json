{
    "schema_version": "biomedpilot.analysis_modules.v1",
    "policy": {
        "frontend_boundary": "submit_tasks_and_consume_standard_result_packages_only",
        "main_backend_boundary": "task_queue_status_file_management_result_index_only",
        "analysis_worker_boundary": "R_and_external_scientific_tools_run_only_in_dedicated_analysis_environments",
        "runtime_install_policy": "forbidden_in_user_request_flow",
        "default_development_policy": "app_dev_must_start_without_full_analysis_dependencies"
    },
    "standard_entrypoint": "analysis/runners/run_module.R",
    "standard_result_package": {
        "required_files": [
            "result.json",
            "provenance.json"
        ],
        "payload_schemas": {
            "result.json": "analysis/schemas/output/result.schema.json",
            "provenance.json": "analysis/schemas/output/provenance.schema.json"
        },
        "required_directories": [
            "tables",
            "plots",
            "reports",
            "logs"
        ]
    },
    "modules": [
        {
            "module_id": "deg",
