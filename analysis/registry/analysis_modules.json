                "mock": {
                    "supported": true,
                    "fixture_input": "analysis/fixtures/inputs/deg/module_input.json",
                    "fixture_output_package": "analysis/fixtures/outputs/deg/mock_result_package"
                },
                "lite": {
                    "supported": true,
                    "fixture_input": "analysis/fixtures/inputs/deg/module_input_lite.json",
                    "runner": "analysis/runners/run_module.R",
                    "worker_backend": "rscript",
                    "environment": "r-bio-core",
                    "result_semantics": "testing_level",
                    "capability": "base_r_two_group_deg_fixture",
                    "clinical_conclusion_policy": "not_generated"
                },
                "full": {
                    "supported": false,
                    "blocker": "full_r_worker_container_not_available"
                }
            },
            "analysis_environment": "r-bio-core",
            "full_environment": "r-bio-full",
            "module_manifest": "analysis/modules/deg/module.json",
            "result_index_task_types": [
                "deg",
