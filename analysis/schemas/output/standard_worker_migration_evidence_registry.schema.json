{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "biomedpilot.analysis.standard_worker_migration_evidence_registry.v1",
  "title": "BioMedPilot standard worker migration evidence registry",
  "type": "object",
  "required": [
    "schema_version",
    "policy",
    "expected_module_ids",
    "evidence_entries"
  ],
  "properties": {
    "schema_version": {
      "const": "biomedpilot.analysis.standard_worker_migration_evidence_registry.v1"
    },
    "policy": {
      "type": "object",
      "required": [
        "registry_is_authoritative",
        "expected_module_ids_are_authoritative",
        "migration_completion_requires_schema_valid_evidence",
        "mock_lite_and_legacy_sidecar_evidence_forbidden",
        "manual_scoped_migration_only"
      ],
      "properties": {
        "registry_is_authoritative": {"const": true},
        "expected_module_ids_are_authoritative": {"const": true},
        "migration_completion_requires_schema_valid_evidence": {"const": true},
        "mock_lite_and_legacy_sidecar_evidence_forbidden": {"const": true},
        "manual_scoped_migration_only": {"const": true}
      },
      "additionalProperties": true
    },
    "expected_module_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "evidence_entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "module_id",
          "evidence"
        ],
        "properties": {
          "module_id": {"type": "string", "minLength": 1},
          "evidence": {"type": "object"}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
