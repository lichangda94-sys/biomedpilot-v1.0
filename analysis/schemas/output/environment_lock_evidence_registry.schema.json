{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "biomedpilot.analysis.environment_lock_evidence_registry.v1",
  "title": "BioMedPilot analysis environment lock evidence registry",
  "type": "object",
  "required": [
    "schema_version",
    "policy",
    "expected_environment_ids",
    "evidence_entries"
  ],
  "properties": {
    "schema_version": {"const": "biomedpilot.analysis.environment_lock_evidence_registry.v1"},
    "policy": {
      "type": "object",
      "required": [
        "registry_is_authoritative",
        "expected_environment_ids_are_authoritative",
        "restored_full_environment_requires_schema_valid_evidence",
        "manual_scoped_environment_restoration_only",
        "runtime_package_install",
        "runtime_resource_download"
      ],
      "properties": {
        "registry_is_authoritative": {"const": true},
        "expected_environment_ids_are_authoritative": {"const": true},
        "restored_full_environment_requires_schema_valid_evidence": {"const": true},
        "manual_scoped_environment_restoration_only": {"const": true},
        "runtime_package_install": {"const": "forbidden"},
        "runtime_resource_download": {"const": "forbidden"}
      },
      "additionalProperties": true
    },
    "expected_environment_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "evidence_entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["environment_id", "evidence_path"],
        "properties": {
          "environment_id": {"type": "string", "minLength": 1},
          "evidence_path": {"type": "string", "minLength": 1},
          "external_evidence_path": {"type": "string", "minLength": 1},
          "evidence_source": {"enum": ["docker_hub", "internal_registry", "local_image_tar"]},
          "source_digest": {"type": "string"},
          "source_attestation_path": {"type": "string"},
          "image_tar_path": {"type": "string"},
          "image_tar_hash": {"type": "string"},
          "lock_profile": {"type": "string"},
          "lock_profile_version": {"type": "string"},
          "renv_lock_package_count": {"type": "integer"},
          "required_package_set": {"type": "array"},
          "missing_required_packages": {"type": "array"},
          "renv_bootstrap_version": {"type": "string"},
          "renv_bootstrap_source": {"type": "string"},
          "validation_status": {"type": "string"},
          "notes": {"type": "string"}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
