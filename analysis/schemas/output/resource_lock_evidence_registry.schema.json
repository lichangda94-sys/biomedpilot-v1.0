{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "biomedpilot.analysis.resource_lock_evidence_registry.v1",
  "title": "BioMedPilot analysis resource lock evidence registry",
  "type": "object",
  "required": [
    "schema_version",
    "policy",
    "expected_resource_ids",
    "evidence_entries"
  ],
  "properties": {
    "schema_version": {"const": "biomedpilot.analysis.resource_lock_evidence_registry.v1"},
    "policy": {
      "type": "object",
      "required": [
        "registry_is_authoritative",
        "expected_resource_ids_are_authoritative",
        "locked_resource_requires_schema_valid_evidence",
        "manual_scoped_resource_lock_only",
        "runtime_download_allowed"
      ],
      "properties": {
        "registry_is_authoritative": {"const": true},
        "expected_resource_ids_are_authoritative": {"const": true},
        "locked_resource_requires_schema_valid_evidence": {"const": true},
        "manual_scoped_resource_lock_only": {"const": true},
        "runtime_download_allowed": {"const": false}
      },
      "additionalProperties": true
    },
    "expected_resource_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "evidence_entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["resource_id", "evidence_path"],
        "properties": {
          "resource_id": {"type": "string", "minLength": 1},
          "evidence_path": {"type": "string", "minLength": 1}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
