{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "biomedpilot.analysis.result.v1",
  "title": "BioMedPilot standard analysis result payload",
  "type": "object",
  "required": [
    "schema_version",
    "module_id",
    "mode",
    "task_id",
    "status",
    "result_semantics",
    "summary",
    "tables",
    "plots",
    "reports",
    "blockers",
    "warnings",
    "created_at"
  ],
  "properties": {
    "schema_version": {"const": "biomedpilot.analysis.result.v1"},
    "module_id": {"type": "string", "minLength": 1},
    "mode": {"enum": ["mock", "lite", "full"]},
    "task_id": {"type": "string", "minLength": 1},
    "status": {"enum": ["passed", "blocked", "failed"]},
    "result_semantics": {"type": "string", "minLength": 1},
    "summary": {"type": "object"},
    "tables": {"type": "array", "items": {"$ref": "#/$defs/artifact"}},
    "plots": {"type": "array", "items": {"$ref": "#/$defs/artifact"}},
    "reports": {"type": "array", "items": {"$ref": "#/$defs/artifact"}},
    "blockers": {"type": "array", "items": {"type": "string"}},
    "warnings": {"type": "array", "items": {"type": "string"}},
    "created_at": {"type": "string"}
  },
  "$defs": {
    "artifact": {
      "type": "object",
      "required": ["artifact_type", "path"],
      "properties": {
        "artifact_type": {"type": "string", "minLength": 1},
        "path": {"type": "string", "minLength": 1}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
