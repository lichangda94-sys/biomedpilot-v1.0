{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "biomedpilot.analysis.evidence_template_package.v1",
  "title": "BioMedPilot analysis external evidence template package",
  "type": "object",
  "required": [
    "schema_version",
    "created_at",
    "worktree",
    "architecture_status",
    "full_analysis_activation_gate_status",
    "execution_policy",
    "install_policy",
    "template_policy",
    "registry_paths",
    "expected_evidence_scope",
    "environment_lock_evidence_templates",
    "resource_lock_evidence_templates",
    "standard_worker_migration_evidence_templates",
    "blockers",
    "remediation_actions",
    "template_counts"
  ],
  "properties": {
    "schema_version": {"const": "biomedpilot.analysis.evidence_template_package.v1"},
    "created_at": {"type": "string", "minLength": 1},
    "worktree": {"type": "string", "minLength": 1},
    "architecture_status": {"type": "string", "minLength": 1},
    "full_analysis_activation_gate_status": {"type": "string", "minLength": 1},
    "execution_policy": {"const": "read_only_no_worker_execution_no_runtime_install_no_resource_download"},
    "install_policy": {"const": "no_runtime_package_install_or_resource_download"},
    "template_policy": {"type": "object"},
    "registry_paths": {"type": "object"},
    "expected_evidence_scope": {
      "type": "object",
      "required": [
        "scope_policy",
        "expected_environment_ids",
        "missing_environment_ids",
        "expected_resource_ids",
        "missing_resource_ids",
        "expected_module_ids",
        "passed_module_ids",
        "blocked_module_ids",
        "missing_module_ids"
      ]
    },
    "environment_lock_evidence_templates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "schema_version",
          "environment_id",
          "package_lock_hash",
          "renv_lock_content",
          "docker_image",
          "runtime_package_install",
          "runtime_resource_download",
          "forbidden_evidence_sources"
        ]
      }
    },
    "resource_lock_evidence_templates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "schema_version",
          "resource_id",
          "hash",
          "cache_content",
          "runtime_download_allowed",
          "forbidden_evidence_sources"
        ]
      }
    },
    "standard_worker_migration_evidence_templates": {"type": "array"},
    "blockers": {"type": "object"},
    "remediation_actions": {
      "type": "object",
      "required": [
        "schema_version",
        "environment_next_actions",
        "environment_action_summary",
        "resource_next_actions",
        "resource_action_summary",
        "module_next_actions",
        "module_action_summary",
        "action_policy"
      ],
      "properties": {
        "schema_version": {"const": "biomedpilot.analysis.evidence_template_remediation_actions.v1"},
        "environment_next_actions": {"type": "array"},
        "environment_action_summary": {"type": "object"},
        "resource_next_actions": {"type": "array"},
        "resource_action_summary": {"type": "object"},
        "module_next_actions": {"type": "array"},
        "module_action_summary": {"type": "object"},
        "action_policy": {"const": "planning_only_not_readiness_evidence"}
      }
    },
    "remediation_scope": {"type": "object"},
    "template_counts": {"type": "object"},
    "schema_validation_status": {"type": "string"},
    "schema_blockers": {"type": "array"}
  },
  "additionalProperties": true
}
