{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "biomedpilot.analysis.environment_lock_evidence.v1",
  "title": "BioMedPilot analysis environment lock evidence",
  "type": "object",
  "required": [
    "schema_version",
    "environment_id",
    "status",
    "r_version",
    "bioconductor_version",
    "package_lock_hash",
    "renv_lock_content",
    "docker_image",
    "dockerfile",
    "renv_lock",
    "runtime_package_install",
    "runtime_resource_download",
    "allowed_module_ids",
    "evidence_files"
  ],
  "properties": {
    "schema_version": {"const": "biomedpilot.analysis.environment_lock_evidence.v1"},
    "environment_id": {"type": "string", "minLength": 1},
    "status": {"type": "string", "minLength": 1},
    "r_version": {"type": "string", "minLength": 1},
    "bioconductor_version": {"type": "string", "minLength": 1},
    "package_lock_hash": {
      "type": "object",
      "required": ["algorithm", "value"],
      "properties": {
        "algorithm": {"type": "string", "minLength": 1},
        "value": {"type": "string", "minLength": 1}
      }
    },
    "renv_lock_content": {
      "type": "object",
      "required": ["policy_status", "packages_non_empty"],
      "properties": {
        "policy_status": {"type": "string", "minLength": 1},
        "packages_non_empty": {"const": true},
        "package_count": {"type": "integer"}
      }
    },
    "docker_image": {
      "type": "object",
      "required": ["image_ref", "digest", "architecture", "build_status", "build_log"],
      "properties": {
        "image_ref": {"type": "string", "minLength": 1},
        "digest": {
          "type": "object",
          "required": ["algorithm", "value"],
          "properties": {
            "algorithm": {"const": "sha256"},
            "value": {"type": "string", "minLength": 1}
          }
        },
        "architecture": {"type": "string", "minLength": 1},
        "build_status": {"const": "built"},
        "build_log": {"type": "string", "minLength": 1}
      }
    },
    "dockerfile": {"type": "string", "minLength": 1},
    "renv_lock": {"type": "string", "minLength": 1},
    "runtime_package_install": {"const": "forbidden"},
    "runtime_resource_download": {"const": "forbidden"},
    "allowed_module_ids": {"type": "array"},
    "evidence_files": {"type": "array"},
    "created_at": {"type": "string"},
    "notes": {"type": "string"}
  },
  "additionalProperties": true
}
