{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "biomedpilot.analysis.environment_lock_evidence.v1",
  "title": "BioMedPilot analysis environment lock evidence",
  "type": "object",
  "required": [
    "schema_version",
    "environment_id",
    "environment_class",
    "status",
    "r_version",
    "bioconductor_version",
    "package_lock_hash",
    "renv_lock_content",
    "docker_image",
    "evidence_source",
    "base_image",
    "base_image_expected",
    "source_digest",
    "registry_preflight_status",
    "docker_build_status",
    "docker_load_status",
    "equivalence_claim",
    "equivalence_validation_status",
    "docker_image_digest",
    "docker_build_log_path",
    "docker_inspect_path",
    "dockerfile",
    "dockerfile_path",
    "renv_lock",
    "renv_lock_path",
    "renv_lock_hash",
    "lock_profile",
    "lock_profile_version",
    "renv_lock_package_count",
    "required_package_set",
    "missing_required_packages",
    "renv_lock_generate_log_path",
    "renv_lock_generate_metadata_path",
    "renv_bootstrap_status",
    "renv_bootstrap_version",
    "renv_bootstrap_source",
    "renv_bootstrap_version_path",
    "renv_bootstrap_source_path",
    "renv_restore_status",
    "renv_restore_log_path",
    "renv_status_path",
    "r_session_info_path",
    "runtime_package_install",
    "runtime_resource_download",
    "allowed_module_ids",
    "evidence_files",
    "package_inventory_path",
    "created_at",
    "created_by",
    "validation_status",
    "validation_errors",
    "evidence_hash"
  ],
  "properties": {
    "schema_version": {"const": "biomedpilot.analysis.environment_lock_evidence.v1"},
    "environment_id": {"type": "string", "minLength": 1},
    "environment_class": {"type": "string", "minLength": 1},
    "status": {"type": "string", "minLength": 1},
    "r_version": {"type": "string", "minLength": 1},
    "bioconductor_version": {"type": "string", "minLength": 1},
    "package_lock_hash": {
      "type": "object",
      "required": ["algorithm", "value"],
      "properties": {
        "algorithm": {"type": "string", "minLength": 1},
        "value": {"type": "string", "minLength": 1}
      }
    },
    "renv_lock_content": {
      "type": "object",
      "required": ["policy_status", "packages_non_empty"],
      "properties": {
        "policy_status": {"type": "string", "minLength": 1},
        "packages_non_empty": {"const": true},
        "package_count": {"type": "integer"}
      }
    },
    "docker_image": {
      "type": "object",
      "required": ["image_ref", "digest", "architecture", "build_status", "build_log"],
      "properties": {
        "image_ref": {"type": "string", "minLength": 1},
        "digest": {
          "type": "object",
          "required": ["algorithm", "value"],
          "properties": {
            "algorithm": {"const": "sha256"},
            "value": {"type": "string", "minLength": 1}
          }
        },
        "architecture": {"type": "string", "minLength": 1},
        "build_status": {"enum": ["built", "not_required", "not_built", "blocked_by_registry_access", "partial"]},
        "build_log": {"type": "string", "minLength": 1}
      }
    },
    "evidence_source": {"enum": ["docker_hub", "internal_registry", "local_image_tar"]},
    "base_image": {"type": "string", "minLength": 1},
    "base_image_expected": {"type": "string", "minLength": 1},
    "source_registry": {"type": "string"},
    "source_digest": {"type": "string"},
    "source_attestation_path": {"type": "string"},
    "image_tar_path": {"type": "string"},
    "image_tar_hash": {"type": "string"},
    "registry_preflight_status": {"type": "string"},
    "registry_preflight_error": {"type": "string"},
    "docker_build_status": {"type": "string", "minLength": 1},
    "docker_load_status": {"type": "string"},
    "equivalence_claim": {"type": "string", "minLength": 1},
    "equivalence_validation_status": {"type": "string", "minLength": 1},
    "docker_image_digest": {"type": "string", "minLength": 1},
    "docker_build_log_path": {"type": "string", "minLength": 1},
    "docker_inspect_path": {"type": "string", "minLength": 1},
    "dockerfile": {"type": "string", "minLength": 1},
    "dockerfile_path": {"type": "string", "minLength": 1},
    "renv_lock": {"type": "string", "minLength": 1},
    "renv_lock_path": {"type": "string", "minLength": 1},
    "renv_lock_hash": {"type": "string", "minLength": 1},
    "lock_profile": {"type": "string", "minLength": 1},
    "lock_profile_version": {"type": "string", "minLength": 1},
    "renv_lock_package_count": {"type": "integer", "minimum": 1},
    "required_package_set": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "missing_required_packages": {
      "type": "array",
      "items": {"type": "string"}
    },
    "renv_lock_generate_log_path": {"type": "string", "minLength": 1},
    "renv_lock_generate_metadata_path": {"type": "string", "minLength": 1},
    "renv_bootstrap_status": {"type": "string", "minLength": 1},
    "renv_bootstrap_version": {"type": "string", "minLength": 1},
    "renv_bootstrap_source": {"type": "string", "minLength": 1},
    "renv_bootstrap_version_path": {"type": "string", "minLength": 1},
    "renv_bootstrap_source_path": {"type": "string", "minLength": 1},
    "renv_restore_status": {"type": "string", "minLength": 1},
    "renv_restore_log_path": {"type": "string", "minLength": 1},
    "renv_status_path": {"type": "string", "minLength": 1},
    "r_session_info_path": {"type": "string", "minLength": 1},
    "runtime_package_install": {"const": "forbidden"},
    "runtime_resource_download": {"const": "forbidden"},
    "allowed_module_ids": {"type": "array"},
    "evidence_files": {"type": "array"},
    "package_inventory_path": {"type": "string", "minLength": 1},
    "created_at": {"type": "string"},
    "created_by": {"type": "string", "minLength": 1},
    "validation_status": {"type": "string", "minLength": 1},
    "validation_errors": {"type": "array"},
    "evidence_hash": {"type": "string", "minLength": 1},
    "notes": {"type": "string"}
  },
  "additionalProperties": true
}
