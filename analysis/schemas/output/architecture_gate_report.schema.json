{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "biomedpilot.analysis.architecture_gate_report.v1",
  "title": "BioMedPilot analysis architecture gate report",
  "type": "object",
  "required": [
    "schema_version",
    "created_at",
    "worktree",
    "status",
    "require_full_ready",
    "architecture_status",
    "requirement_summary",
    "requirement_rows",
    "priority_issue_lists",
    "top_architecture_risks",
    "p0_issues",
    "p1_issues",
    "full_analysis_activation_gate",
    "module_interface_matrix",
    "module_interface_rows",
    "external_tool_adapter_matrix",
    "external_tool_adapter_rows",
    "task_system_boundary_matrix",
    "task_system_boundary_rows",
    "runtime_acquisition_scan",
    "default_dependency_scan",
    "environment_readiness",
    "resource_readiness",
    "standard_worker_migration_matrix",
    "full_activation_module_matrix",
    "full_activation_module_rows",
    "standard_worker_migration_rows",
    "remediation_queue",
    "remediation_summary",
    "blockers",
    "warnings",
    "execution_policy",
    "exit_policy"
  ],
  "properties": {
    "schema_version": {"const": "biomedpilot.analysis.architecture_gate_report.v1"},
    "created_at": {"type": "string", "minLength": 1},
    "worktree": {"type": "string", "minLength": 1},
    "status": {"type": "string", "minLength": 1},
    "require_full_ready": {"type": "boolean"},
    "architecture_status": {"type": "string", "minLength": 1},
    "requirement_summary": {"type": "object"},
    "requirement_rows": {"type": "array"},
    "priority_issue_lists": {"type": "object"},
    "top_architecture_risks": {"type": "array"},
    "p0_issues": {"type": "array"},
    "p1_issues": {"type": "array"},
    "full_analysis_activation_gate": {"type": "object"},
    "module_interface_matrix": {"type": "object"},
    "module_interface_rows": {"type": "array"},
    "external_tool_adapter_matrix": {"type": "object"},
    "external_tool_adapter_rows": {"type": "array"},
    "task_system_boundary_matrix": {"type": "object"},
    "task_system_boundary_rows": {"type": "array"},
    "runtime_acquisition_scan": {"type": "object"},
    "default_dependency_scan": {"type": "object"},
    "environment_readiness": {"type": "object"},
    "resource_readiness": {"type": "object"},
    "standard_worker_migration_matrix": {"type": "object"},
    "full_activation_module_matrix": {"type": "object"},
    "full_activation_module_rows": {"type": "array"},
    "standard_worker_migration_rows": {"type": "array"},
    "remediation_queue": {"type": "object"},
    "remediation_summary": {"type": "object"},
    "blockers": {"type": "array"},
    "warnings": {"type": "array"},
    "execution_policy": {"const": "read_only_no_worker_execution_no_runtime_install_no_resource_download"},
    "exit_policy": {"type": "string", "minLength": 1},
    "schema_validation_status": {"type": "string"},
    "schema_blockers": {"type": "array"}
  },
  "additionalProperties": true
}
